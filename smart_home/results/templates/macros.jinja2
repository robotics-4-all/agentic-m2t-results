{% macro render_generator_class(generator) %}
{%- if classname(generator) == 'ConstantGenerator' -%}
class ConstantGenerator(ValueGenerator):
    """Generator that returns a constant value."""
    
    def __init__(self, value: float) -> None:
        self.value = value
    
    def generate(self) -> float:
        """Return the constant value."""
        return self.value
{%- elif classname(generator) == 'LinearGenerator' -%}
class LinearGenerator(ValueGenerator):
    """Generator that produces linearly increasing values."""
    
    def __init__(self, start: float, step: float) -> None:
        self.start = start
        self.step = step
        self.current = start
    
    def generate(self) -> float:
        """Return the next value in the linear sequence."""
        value = self.current
        self.current += self.step
        return value
{%- elif classname(generator) == 'GaussianGenerator' -%}
class GaussianGenerator(ValueGenerator):
    """Generator that produces values with Gaussian distribution."""
    
    def __init__(self, value: float, max_value: float, sigma: float) -> None:
        self.value = value
        self.max_value = max_value
        self.sigma = sigma
    
    def generate(self) -> float:
        """Return a value sampled from Gaussian distribution."""
        result = random.gauss(self.value, self.sigma)
        return min(result, self.max_value)
{%- elif classname(generator) == 'SinusGenerator' -%}
class SinusGenerator(ValueGenerator):
    """Generator that produces sinusoidal values."""
    
    def __init__(self, dc: float, amplitude: float, step: float) -> None:
        self.dc = dc
        self.amplitude = amplitude
        self.step = step
        self.phase = 0.0
    
    def generate(self) -> float:
        """Return the next value in the sinusoidal sequence."""
        value = self.dc + self.amplitude * math.sin(self.phase)
        self.phase += self.step
        return value
{%- elif classname(generator) == 'SawtoothGenerator' -%}
class SawtoothGenerator(ValueGenerator):
    """Generator that produces sawtooth wave values."""
    
    def __init__(self, min_val: float, max_val: float, step: float) -> None:
        self.min_val = min_val
        self.max_val = max_val
        self.step = step
        self.current = min_val
    
    def generate(self) -> float:
        """Return the next value in the sawtooth sequence."""
        value = self.current
        self.current += self.step
        if self.current > self.max_val:
            self.current = self.min_val
        return value
{%- elif classname(generator) == 'ReplayGenerator' -%}
class ReplayGenerator(ValueGenerator):
    """Generator that replays values from a list or file."""
    
    def __init__(self, values: Optional[List[Any]] = None, filepath: Optional[str] = None, times: int = 1) -> None:
        self.times = times
        self.current_iteration = 0
        self.current_index = 0
        
        if filepath:
            # Load values from file
            with open(filepath, 'r') as f:
                import json
                self.values = json.load(f)
        elif values:
            self.values = values
        else:
            self.values = []
    
    def generate(self) -> Any:
        """Return the next value from the replay sequence."""
        if not self.values:
            return None
        
        if self.current_iteration >= self.times and self.times > 0:
            # Replay completed, return last value
            return self.values[-1]
        
        value = self.values[self.current_index]
        self.current_index += 1
        
        if self.current_index >= len(self.values):
            self.current_index = 0
            self.current_iteration += 1
        
        return value
{%- endif -%}
{% endmacro %}

{% macro render_noise_class(noise) %}
{%- if classname(noise) == 'UniformNoise' -%}
class UniformNoise(NoiseDefinition):
    """Noise generator with uniform distribution."""
    
    def __init__(self, min_val: float, max_val: float) -> None:
        self.min_val = min_val
        self.max_val = max_val
    
    def apply(self, value: float) -> float:
        """Apply uniform noise to the given value."""
        noise = random.uniform(self.min_val, self.max_val)
        return value + noise
{%- elif classname(noise) == 'GaussianNoise' -%}
class GaussianNoise(NoiseDefinition):
    """Noise generator with Gaussian distribution."""
    
    def __init__(self, mu: float, sigma: float) -> None:
        self.mu = mu
        self.sigma = sigma
    
    def apply(self, value: float) -> float:
        """Apply Gaussian noise to the given value."""
        noise = random.gauss(self.mu, self.sigma)
        return value + noise
{%- endif -%}
{% endmacro %}

