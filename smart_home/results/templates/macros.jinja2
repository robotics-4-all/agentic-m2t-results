{%- elif classname(noise) == 'GaussianNoise' -%}
NoiseWrapper({{ render_generator_base(generator) }}, GaussianNoise({{ noise.mu }}, {{ noise.sigma }}))
{%- endif -%}
{%- else -%}
{{ render_generator_base(generator) }}
{%- endif -%}
