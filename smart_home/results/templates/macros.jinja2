    def __init__(self) -> None:
        self.name = "{{ entity.name }}"
        self.entity_type = "{{ entity.type }}"
        self.topic = "{{ entity.topic }}"
        self.freq = {{ entity.freq }}
        self.broker_name = "{{ entity.broker.name }}"
        
        # Initialize attributes
